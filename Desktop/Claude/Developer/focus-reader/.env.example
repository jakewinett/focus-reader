# Focus Reader — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic API key — used in Sprint 3+ for AI calls.
# For local dev: set this and the app calls the API directly from the browser.
# For production: remove this and use the Vercel Edge Function proxy (api/claude.js).
# See architecture doc Section 9.1 for security notes.
VITE_ANTHROPIC_API_KEY=your_key_here
