# Focus Reader — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Local development ─────────────────────────────────────────────────────────
# Set this to your Anthropic API key to enable AI features while running
# `npm run dev`. The VITE_ prefix makes it available to the browser at dev time.
#
# ⚠  Do NOT set this in production or Vercel deployments. It would embed the
#    key in the client bundle. Use ANTHROPIC_API_KEY (below) instead.
VITE_ANTHROPIC_API_KEY=your_key_here

# ── Production — Vercel Edge Function (api/claude.js) ────────────────────────
# Set this in the Vercel dashboard under:
#   Project → Settings → Environment Variables
#
# NO "VITE_" prefix — this key stays server-side and is never embedded in the
# client bundle. The Edge Function at api/claude.js picks it up automatically.
#
# ANTHROPIC_API_KEY=your_key_here   ← set in Vercel dashboard, not in this file
